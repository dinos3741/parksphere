{
  "expo": {
    "name": "ParksphereMobileApp",
    "slug": "ParksphereMobileApp",
    "scheme": "parksphere",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "homeIndicator": "hidden",
      "bundleIdentifier": "com.konstantinos.parksphere",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use location to detect parking.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We use location in background to detect parking.",
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.konstantinos.parksphere",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "expo-audio",
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow Parksphere to detect your parking spots automatically even when the app is in the background.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-notifications"
    ]
  }
}
